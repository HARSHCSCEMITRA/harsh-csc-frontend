VITE_API_URL=http://localhost:8000

# Set to "true" to use mock data instead of real API (useful for development)
VITE_USE_MOCK=true

# Store contact info (used in checkout/tracking pages)
VITE_STORE_PHONE=+91-XXXXXXXXXX
VITE_STORE_WHATSAPP=91XXXXXXXXXX
VITE_STORE_ADDRESS=Your CSC Center Address, City, Rajasthan
