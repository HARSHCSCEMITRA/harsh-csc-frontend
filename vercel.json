{
  "redirects": [
    {
      "source": "/software/Zamify_Setup.zip",
      "destination": "https://drive.google.com/drive/folders/1TAhnbOI2-wVw4usLDd7MI5m_7vAEBHYY?usp=sharing",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/admin/:endpoint",
      "destination": "/api/admin.js?endpoint=:endpoint"
    },
    {
      "source": "/api/auth/admin/:endpoint",
      "destination": "/api/auth-admin.js?endpoint=:endpoint"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "crons": [
    {
      "path": "/api/fetch-updates",
      "schedule": "0 6 * * *"
    }
  ]
}
